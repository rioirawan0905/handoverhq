rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'yesaya.rio@gmail.com'; }
    function isMember() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'member']; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.role in ['admin', 'member', 'viewer'];
    }

    function isValidHandover(data) {
      return data.keys().hasAll(['title', 'status', 'creatorId', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.status in ['pending', 'in progress', 'done'] &&
             data.creatorId == request.auth.uid &&
             (data.keys().hasAny(['content']) ? data.content is string && data.content.size() <= 5000 : true);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'read', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.message is string && data.message.size() <= 500 &&
             data.read == false;
    }

    // 4. Collection Matches
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /handovers/{handoverId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidHandover(incoming());
      allow update: if isSignedIn() && (
        (existing().creatorId == request.auth.uid || isAdmin()) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'remarks', 'updatedAt']))
      );
      allow delete: if isSignedIn() && (existing().creatorId == request.auth.uid || isAdmin());
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow create: if false; // System generated or specific rules
      allow update: if isSignedIn() && userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && userId == request.auth.uid;
    }
  }
}
